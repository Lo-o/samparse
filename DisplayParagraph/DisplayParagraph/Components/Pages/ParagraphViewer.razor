@page "/paragraph-viewer"
@rendermode InteractiveServer
@using Be.Fgov.Ehealth.Samws.V2.Chapteriv.Submit
@using Be.Fgov.Ehealth.Samws.V2.Export
@using DisplayParagraph.Services
@using Samparse
@inject SamDataService SamData

<PageTitle>Paragraph Viewer</PageTitle>

<h2>Chapter IV Paragraph Viewer</h2>

<p class="page-byline">
    Resolves which verses of a Chapter IV reimbursement paragraph apply to a given patient,
    doctor and prescription type on a reference date, and summarises whether the paragraph
    as a whole is theoretically applicable.
</p>

<details class="page-howto">
    <summary>How to read this page</summary>
    <div class="page-howto-body">
        <ul>
            <li>
                <strong>Verdict callout</strong> — green = no patient/doctor/request restriction is violated;
                red = a mandatory restriction can&rsquo;t be satisfied; amber = a relevant input is missing
                (e.g. patient sex unspecified, but the paragraph contains a sex-restricted choice).
            </li>
            <li>
                <strong>Yellow rows</strong> mark verses the patient/doctor fail individually.
                A yellow row can still leave the overall verdict green if it sits in an <em>optional</em>
                branch &mdash; the rollup considers the verse tree as a whole.
            </li>
            <li>
                <strong>Indentation</strong> reflects <code>VerseLevel</code>; the
                <span class="text-muted">&#9744;</span> glyph marks a checkbox alternative inside a choice group.
            </li>
            <li>
                <strong>Sex / Age limits / Qual.</strong> show the verse&rsquo;s own restrictions when present.
                Empty cells mean the verse imposes no restriction on that axis.
            </li>
            <li>
                <strong>Req.</strong> &mdash; <code>N</code> = new prescription only,
                <code>P</code> = renewal only, blank = either.
            </li>
            <li>
                <strong>EXCL chip</strong> &mdash; an exclusion verse, phrased as <em>&ldquo;X is not authorised&rdquo;</em>.
                Visually flagged but treated identically by the applicability check (see docs for nuance).
            </li>
        </ul>
        <p class="page-howto-link">
            <a href="/docs/chapter-iv-applicability">Read the full applicability docs &rarr;</a>
        </p>
    </div>
</details>

<div class="filter-bar">
    <div class="filter-row">
        <div class="filter-field" style="flex: 0 0 14rem">
            <label class="form-label">Paragraph</label>
            <input @bind="paragraphName" @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   class="form-control font-monospace" placeholder="e.g. 12850000" />
        </div>
        <div class="filter-field" style="flex: 0 0 11rem">
            <label class="form-label">Reference date</label>
            <input type="date" @bind="referenceDate" class="form-control" />
        </div>
        <div class="filter-field" style="flex: 0 0 9rem">
            <label class="form-label">Patient sex</label>
            <select @bind="patientSex" class="form-select">
                <option value="">—</option>
                <option value="M">Male (M)</option>
                <option value="F">Female (F)</option>
            </select>
        </div>
        <div class="filter-field" style="flex: 0 0 12rem">
            <label class="form-label">
                Patient date of birth
                <span class="form-hint">@PatientAgeHint()</span>
            </label>
            <input type="date" @bind="patientDob" @bind:event="oninput" class="form-control" />
        </div>
        <div class="filter-field filter-action">
            <button class="btn btn-primary" @onclick="Load">Load</button>
        </div>
    </div>
    <div class="filter-row">
        <div class="filter-field" style="flex: 0 0 11rem">
            <label class="form-label">Request type</label>
            <select @bind="requestType" class="form-select">
                <option value="">—</option>
                <option value="N">New prescription</option>
                <option value="P">Renewal</option>
            </select>
        </div>
        <div class="filter-field" style="flex: 1 1 24rem; max-width: 30rem">
            <label class="form-label">Doctor qualifications <span class="form-hint">(comma-separated CV codes)</span></label>
            <input @bind="doctorCvs" class="form-control font-monospace" placeholder="e.g. 668, 650" />
        </div>
    </div>
</div>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (rows is not null && loadedParagraph is not null)
{
    var applicability = ApplicabilityChecker.CouldApplyTo(
        loadedParagraph, BuildPatient(), BuildDoctor(), BuildIsRenewal(), referenceDate, SamData.ChapterIvIndex);

    <div class="callout @ApplicabilityCalloutClass(applicability)">
        <span class="callout-icon">@ApplicabilityIcon(applicability)</span>
        <div>
            <div class="callout-title">Paragraph applicability: @applicability</div>
            <div class="callout-body">@ApplicabilityExplanation(applicability)</div>
        </div>
    </div>

    @if (rows.Count == 0)
    {
        <p class="text-muted">No active verses for this paragraph on the selected date.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:3rem" title="Sequence within paragraph">Seq</th>
                        <th style="width:5rem" title="Unique verse number">Verse #</th>
                        <th>Text (NL)</th>
                        <th style="width:4rem" class="text-center" title="Sex restriction">Sex</th>
                        <th style="width:10rem" title="Age limits">Age limits</th>
                        <th style="width:4rem" class="text-center" title="N = new prescription only, P = renewal only, blank = both">Req.</th>
                        <th style="width:8rem" title="Doctor qualification list">Qual.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        var verseCompat = ApplicabilityChecker.VerseCompatible(
                            row.Data, BuildPatient(), BuildDoctor(), BuildIsRenewal(), referenceDate, SamData.ChapterIvIndex);
                        var isExclusion = row.Data.VerseTypeSpecified && row.Data.VerseType == VerseTypeType.E;
                        var rowClass = string.Join(" ",
                            verseCompat == ApplicabilityResult.NotApplicable ? "table-warning" : "",
                            isExclusion ? "verse-exclusion" : "").Trim();

                        <tr class="@rowClass">
                            <td class="text-muted">@row.VerseSeq</td>
                            <td class="font-monospace">@row.Data.VerseNum</td>
                            <td style="padding-left: @(row.Data.VerseLevel * 24)px">
                                @if (isExclusion)
                                {
                                    <span class="verse-tag verse-tag-exclusion" title="Exclusion verse — describes a condition under which reimbursement is not authorised">EXCL</span>
                                }
                                @if (row.Data.CheckBoxInd)
                                {
                                    <span class="text-muted me-1" title="Checkbox alternative">☐</span>
                                }
                                @row.Data.TextNl
                            </td>
                            <td class="text-center">@SexLabel(row.Data)</td>
                            <td>@AgeLimitsLabel(row.Data)</td>
                            <td class="text-center font-monospace">@RequestTypeLabel(row.Data)</td>
                            <td class="font-monospace small">
                                @if (!string.IsNullOrEmpty(row.Data.PurchasingAdvisorQualList))
                                {
                                    <span title="@QualTooltip(row.Data.PurchasingAdvisorQualList)"
                                          style="border-bottom: 1px dotted #888; cursor: help;">
                                        @row.Data.PurchasingAdvisorQualList
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">@rows.Count verse(s) active on @referenceDate.ToShortDateString()</p>
    }
}

@code {
    private string paragraphName = "";
    private DateTime referenceDate = DateTime.Today;
    private string patientSex = "";
    private DateTime? patientDob;
    private string requestType = "";
    private string doctorCvs = "";

    private List<VerseRow>? rows;
    private ParagraphFullDataType? loadedParagraph;
    private string? errorMessage;

    private record VerseRow(int VerseSeq, VerseDataType Data);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Load();
    }

    private Task Load()
    {
        errorMessage = null;

        var paragraph = SamData.Database.ChapterIv!.Paragraph
            .FirstOrDefault(p => p.ParagraphName == paragraphName.Trim());

        if (paragraph is null)
        {
            errorMessage = $"Paragraph '{paragraphName.Trim()}' not found.";
            rows = null;
            loadedParagraph = null;
            return Task.CompletedTask;
        }

        loadedParagraph = paragraph;
        rows = paragraph.Verse
            .OrderBy(v => v.VerseSeq)
            .Select(v => v.Data.FirstOrDefault(d => d.From <= referenceDate && (!d.ToSpecified || d.To >= referenceDate)) is { } data
                ? new VerseRow(v.VerseSeq, data)
                : null)
            .Where(r => r is not null)
            .Select(r => r!)
            .ToList();

        return Task.CompletedTask;
    }

    private PatientContext BuildPatient() => new(
        Sex: patientSex switch { "F" => SexRestrictedType.F, "M" => SexRestrictedType.M, _ => null },
        DateOfBirth: patientDob is { } dob ? DateOnly.FromDateTime(dob) : null);

    private string PatientAgeHint()
    {
        if (patientDob is not { } dob) return "";
        var d = DateOnly.FromDateTime(dob);
        var r = DateOnly.FromDateTime(referenceDate);
        if (d > r) return "(after reference date)";

        var years  = r.Year  - d.Year;
        var months = r.Month - d.Month;
        var days   = r.Day   - d.Day;
        if (days < 0)
        {
            var prev = r.AddMonths(-1);
            days += DateTime.DaysInMonth(prev.Year, prev.Month);
            months--;
        }
        if (months < 0) { months += 12; years--; }

        if (years  > 0) return $"({years} yr {months} mo on {referenceDate:yyyy-MM-dd})";
        if (months > 0) return $"({months} mo {days} d on {referenceDate:yyyy-MM-dd})";
        return $"({days} d on {referenceDate:yyyy-MM-dd})";
    }

    private DoctorContext BuildDoctor()
    {
        var codes = (doctorCvs ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        return codes.Count == 0 ? DoctorContext.Unknown : new DoctorContext(codes);
    }

    private bool? BuildIsRenewal() => requestType switch
    {
        "N" => false,
        "P" => true,
        _   => null,
    };

    private static string RequestTypeLabel(VerseDataType data) =>
        !data.RequestTypeSpecified ? "" :
        data.RequestType == RequestTypeType.N ? "N" : "P";

    private static string ApplicabilityCalloutClass(ApplicabilityResult r) => r switch
    {
        ApplicabilityResult.Applicable    => "callout-good",
        ApplicabilityResult.NotApplicable => "callout-bad",
        _                                 => "callout-warn",
    };

    private static string ApplicabilityIcon(ApplicabilityResult r) => r switch
    {
        ApplicabilityResult.Applicable    => "✓",
        ApplicabilityResult.NotApplicable => "✗",
        _                                 => "?",
    };

    private static string ApplicabilityExplanation(ApplicabilityResult r) => r switch
    {
        ApplicabilityResult.Applicable    => "No mandatory restriction in this paragraph is violated by the current patient/doctor context.",
        ApplicabilityResult.NotApplicable => "A mandatory choice group in this paragraph cannot be satisfied by the current patient/doctor context.",
        _                                 => "Some relevant patient or doctor information is missing, so applicability cannot be decided.",
    };

    private string QualTooltip(string listKey)
    {
        var info = SamData.QualResolver.Resolve(listKey, referenceDate);
        if (info is null) return $"Qualification list {listKey} (not found in reference data)";
        if (info.Members.Count == 0) return $"Qualification list {listKey} (no active CV codes on {referenceDate:yyyy-MM-dd})";
        var lines = info.Members.Select(m => $"  • {m.ProfessionalCv}  {m.NlName ?? "(no name)"}");
        return $"Qualification list {listKey} — {info.Members.Count} CV code(s):\n" + string.Join("\n", lines);
    }

    private static string SexLabel(VerseDataType data) =>
        !data.SexRestrictedSpecified ? "" :
        data.SexRestricted == SexRestrictedType.F ? "♀" : "♂";

    private static string UnitLabel(DurationUnitType unit) => unit switch
    {
        DurationUnitType.D => "d",
        DurationUnitType.W => "wk",
        DurationUnitType.M => "mo",
        DurationUnitType.Y => "yr",
        _ => "?",
    };

    private static string AgeLimitsLabel(VerseDataType data) => (data.MinimumAgeAuthorizedSpecified, data.MaximumAgeAuthorizedSpecified) switch
    {
        (false, false) => "",
        (true,  true)  => $"{data.MinimumAgeAuthorized} {UnitLabel(data.MinimumAgeAuthorizedUnit)} – {data.MaximumAgeAuthorized} {UnitLabel(data.MaximumAgeAuthorizedUnit)}",
        (true,  false) => $"≥ {data.MinimumAgeAuthorized} {UnitLabel(data.MinimumAgeAuthorizedUnit)}",
        (false, true)  => $"≤ {data.MaximumAgeAuthorized} {UnitLabel(data.MaximumAgeAuthorizedUnit)}",
    };
}
