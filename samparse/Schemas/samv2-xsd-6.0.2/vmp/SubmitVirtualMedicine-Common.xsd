  </xs:complexType>
  <xs:complexType name="ChangeVmpType">
    <xs:complexContent>
      <xs:extension base="core:VmpKeyType">
        <xs:sequence>
          <xs:sequence minOccurs="0">
            <xs:group ref="VmpFields" />
            <xs:group ref="VmpReferences" />
          </xs:sequence>
          <xs:element name="VmpComponent" type="ChangeVmpComponentType" minOccurs="0"
            maxOccurs="unbounded" />
        </xs:sequence>
        <xs:attributeGroup ref="core:changeNoChangeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="RemoveVmpType">
    <xs:complexContent>
      <xs:extension base="core:VmpKeyType">
        <xs:attributeGroup ref="core:removeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!--VMP Component -->
  <xs:complexType name="VmpComponentType">
    <xs:complexContent>
      <xs:extension base="core:VmpComponentKeyType">
        <xs:sequence>
          <xs:group ref="VmpComponentFields" />
          <xs:group ref="VmpComponentReferences" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!--VmpComponentKeyType : in SamCommonItems because of use in AM domain-->
  <xs:group name="VmpComponentFields">
    <xs:sequence>
      <xs:element name="PhaseNumber" type="core:PositiveShortType" minOccurs="0" />
      <xs:element name="Name" type="core:Text255Type" />
    </xs:sequence>
  </xs:group>
  <xs:group name="VmpComponentReferences">
    <xs:sequence>
      <xs:element name="VirtualFormCode" type="core:String10Type" />
      <xs:element name="RouteOfAdministrationCode" type="core:String10Type" maxOccurs="unbounded" />
    </xs:sequence>
  </xs:group>
  <xs:complexType name="AddVmpComponentType">
    <xs:complexContent>
      <xs:extension base="VmpComponentType">
        <xs:sequence>
          <xs:element name="VirtualIngredient" type="AddVirtualIngredientType" maxOccurs="unbounded" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="ChangeVmpComponentType">
    <xs:complexContent>
      <xs:extension base="core:VmpComponentKeyType">
        <xs:sequence>
          <xs:sequence minOccurs="0">
            <xs:group ref="VmpComponentFields" />
            <xs:group ref="VmpComponentReferences" />
          </xs:sequence>
          <xs:element name="VirtualIngredient" type="ChangeVirtualIngredientType" minOccurs="0"
            maxOccurs="unbounded" />
        </xs:sequence>
        <xs:attributeGroup ref="core:changeNoChangeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!--VMP Group -->
  <xs:complexType name="VmpGroupType">
    <xs:complexContent>
      <xs:extension base="VmpGroupKeyType">
        <xs:sequence>
          <xs:group ref="VmpGroupFields" />
          <xs:group ref="VmpGroupReferences" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="VmpGroupKeyType">
    <xs:attribute name="code" type="core:PositiveIntType" use="required" />
  </xs:complexType>
  <xs:group name="VmpGroupFields">
    <xs:sequence>
      <xs:element name="Name" type="core:Text255Type">
        <xs:annotation>
          <xs:documentation>Name of this group. This field is translated in French, Dutch, German
            and English. French and Dutch versions are mandatory and others are optional. Example:
            ‘amoxicilline 1g oraal’. </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PatientFrailtyIndicator" type="xs:boolean" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Indicates whether the frailty of the patient has impact on the standard
            dosage. If the value is true, the standard dosage should be adapted according to the
            patient's frailty. </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SingleAdministrationDose" type="core:QuantityType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            <p>
              Defines a single administration dose. Products in the same group can have multiple administration routes, and doses can differ between routes. This element contains the quantity that counts as a single administration dose for all routes. 
            </p>
            <p>
              The unit refers to the reference table Administration Unit, not Standard Unit.
            </p>
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>
  <xs:group name="VmpGroupReferences">
    <xs:sequence>
      <xs:element name="NoGenericPrescriptionReasonCode" type="core:String10Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Indicates the reason why this VMP Group can’t be generically prescribed.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NoSwitchReasonCode" type="core:String10Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>The generic prescription for VMP’s in this group cannot change. The code
            indicates the reason. </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StandardDosageCode" type="core:String10Type" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Standard dosage examples for assistance with creating prescriptions, administration instructions and medication schemes.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>
  <xs:complexType name="AddVmpGroupType">
    <xs:complexContent>
      <xs:extension base="VmpGroupType">
        <xs:attributeGroup ref="core:addMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="ChangeVmpGroupType">
    <xs:complexContent>
      <xs:extension base="VmpGroupType">
        <xs:attributeGroup ref="core:changeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="RemoveVmpGroupType">
    <xs:complexContent>
      <xs:extension base="VmpGroupKeyType">
        <xs:attributeGroup ref="core:removeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!--VTM -->
  <xs:complexType name="VtmType">
    <xs:complexContent>
      <xs:extension base="VtmKeyType">
        <xs:sequence>
          <xs:group ref="VtmFields" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="VtmKeyType">
    <xs:attribute name="code" type="core:PositiveIntType" use="required" />
  </xs:complexType>
  <xs:group name="VtmFields">
    <xs:sequence>
      <xs:element name="Name" type="core:Text255Type" />
    </xs:sequence>
  </xs:group>
  <xs:complexType name="AddVtmType">
    <xs:complexContent>
      <xs:extension base="VtmType">
        <xs:attributeGroup ref="core:addMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="ChangeVtmType">
    <xs:complexContent>
      <xs:extension base="VtmType">
        <xs:attributeGroup ref="core:changeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="RemoveVtmType">
    <xs:complexContent>
      <xs:extension base="VtmKeyType">
        <xs:attributeGroup ref="core:removeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!--Standard Dosage-->
  <xs:complexType name="AddStandardDosageType">
    <xs:complexContent>
      <xs:extension base="StandardDosageType">
        <xs:attributeGroup ref="core:addMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="RemoveStandardDosageType">
    <xs:complexContent>
      <xs:extension base="StandardDosageKeyType">
        <xs:attributeGroup ref="core:removeMetadata" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="StandardDosageKeyType">
    <xs:attribute name="code" type="core:PositiveIntType" use="required" />
  </xs:complexType>
  <xs:complexType name="StandardDosageType">
    <xs:complexContent>
      <xs:extension base="StandardDosageKeyType">
        <xs:sequence>
          <xs:group ref="StandardDosageFields" />
          <xs:group ref="StandardDosageReferences" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:group name="StandardDosageFields">
    <xs:sequence>
      <xs:element name="TargetGroup">
        <xs:annotation>
          <xs:documentation>This Standard Dosage is only applicable to the specified target
            group</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="NEONATE" />
            <xs:enumeration value="PAEDIATRICS" />
            <xs:enumeration value="ADOLESCENT" />
            <xs:enumeration value="ADULT" />
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="KidneyFailureClass" type="xs:int" minOccurs="0">
        <xs:annotation>
          <xs:documentation>If Kidney Failure is a predictor, the Kidney Failure Class defines a
            Standard Dosage based on Creatinine Clearance (Cockcroft-Gault Equation) 0 - Normal
            Kidney Function 1 - Creatinin Clearance between 30 and 60 mL/min 2 - Creatinin
            Clearance between 10 and 30 mL/min 3 - Creatinin Clearance lower than 10 mL/min </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LiverFailureClass" type="xs:int" minOccurs="0">
        <xs:annotation>
          <xs:documentation>If Liver Function Failure is a predictor, the Liver Failure Class
            defines a Standard Dosage based on the Child-Pugh score 0 - Normal Liver Function 1
            - Child Pugh Score 5 or 6 (grade A) 2 - Child Pugh Score 7, 8 or 9 (grade B) 3 -
            Child Pugh Score 10 or more (grade C) </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TreatmentDurationType">
        <xs:annotation>
          <xs:documentation>Treatment duration type.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="ONE_OFF" />
            <xs:enumeration value="TEMPORARY" />
            <xs:enumeration value="CHRONIC" />
            <xs:enumeration value="IF_NECESSARY" />
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="TemporalityDuration" type="core:QuantityType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>If the treatment duration is TEMPORARY and of a fixed length</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TemporalityUserProvided" type="xs:boolean" minOccurs="0">
        <xs:annotation>
          <xs:documentation>If the treatment duration is TEMPORARY and should be defined by the prescriber</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TemporalityNote" type="core:TextType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Free text. If the treatment duration cannot be given as a QuantityType.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Quantity" type="core:Decimal20d4Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The number of dosage units or the fraction of dosage units. E.g. "1" in "1 dosage unit 3 times a day". The quantity can be expressed relative to a certain parameter (e.g. weight, see quantity_param_multiplicator). 
            
            The dosage unit is defined in a VMP Group, a VMP and an AMP as an exact amount of active substance (e.g. 500 mg) or in terms of administration units (e.g. 1 tablet). The dosage unit should correspond to the same amount of active substance(s) on the different levels (VMP Group, VMP and AMP), but can differ in form (e.g. "500 mg" in the VMP Group vs "1 tablet" in the VMP vs "1 dividable tablet" in the AMP).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuantityDenominator" type="core:Decimal20d4Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            If the dosage quantity is represented as a fraction of a dosage unit, this field contains the denominator. E.g. "2" in "1/2 dosage units 3 times a day.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuantityMultiplicator" type="core:String255Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Refers to the reference table Dosage Parameter.
            The dosage expressed in Quantity and QuantityDenominator must be multiplied by this Dosage Parameter. E.g. for a QuantityMultiplicator "weight in kg", Quantity "1" and QuantityDenominator "10", the dosage must be read as "1/10th Dosage Unit per kg".
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuantityRangeLower" type="core:Decimal20d4Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The lower bound (or fraction part of the lower bound) for the usual amount of dosage units per administration.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuantityRangeLowerDenominator" type="core:Decimal20d4Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The denominator for the lower bound for the usual amount of dosage units, if the lower bound is a fraction.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuantityRangeUpper" type="core:Decimal20d4Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The upper bound (or fraction part of the upper bound) for the usual amount of dosage units per administration.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuantityRangeUpperDenominator" type="core:Decimal20d4Type" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The denominator for the upper bound for the usual amount of dosage units, if the upper bound is a fraction.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AdministrationFrequencyQuantity" type="xs:int" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The number of doses to be administered in a timeframe (e.g. "3" in "3 administrations per 1 day") 
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AdministrationFrequencyIsMax" type="xs:boolean" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            This administration frequency indicates a maximum, e.g. "maximum" 4 administrations per day.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AdministrationFrequencyTimeframe" type="core:QuantityType" minOccurs="0">
        <xs:annotation>
